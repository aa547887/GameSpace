@*//每日數據 JSON 匯入（給爬蟲/模擬）
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "匯入每日數據（JSON）";
}
<h2>@ViewData["Title"]</h2>

@if (TempData["msg"] != null)
{
    <div class="alert alert-success">@TempData["msg"]</div>
}
<form method="post" enctype="multipart/form-data" class="d-flex gap-2">
    <input type="file" name="file" accept=".json" class="form-control" />
    <button class="btn btn-primary" type="submit">上傳匯入</button>
    @Html.AntiForgeryToken()
</form>

<pre class="mt-3 small">
[
  { "date":"2025-09-07", "game_name":"Elden Ring", "source":"steam", "metric":"ccu", "value":123456 },
  { "date":"2025-09-07", "game_name":"Elden Ring", "source":"steam", "metric":"reviews_total", "value":987654 }
]
</pre>

