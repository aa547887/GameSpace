пїњ@model GameSpace.Areas.MiniGame.Models.ViewModels.AdminWalletTransactionViewModel
@{
    ViewData["Title"] = "пњљIпњљ∆•пњљпњљ";
    Layout = "~/Areas/MiniGame/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <!-- пњљпњљпњљпњљпњљпњљпњљD -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">пњљIпњљ∆•пњљпњљ</h1>
        <div>
            <a href="@Url.Action("Index", "AdminWallet")" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm">
                <i class="fas fa-arrow-left fa-sm text-white-50"></i> пњљпњљ^пњљCпњљпњљ
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">пњљIпњљ∆•пњљпњљ</h6>
                </div>
                <div class="card-body">
                    <form asp-action="Transaction" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <input asp-for="UserId" type="hidden" />
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">пњљќ§пњљWпњљпњљ</label>
                                    <input type="text" class="form-control" value="@Model.UserName" readonly />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">пњљЎЂeпњљIпњљпњљ</label>
                                    <input type="text" class="form-control" value="@Model.CurrentPoints.ToString("N0")" readonly />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="TransactionType" class="control-label">пњљпњљпњљпњљпњљпњљпњљ *</label>
                                    <select asp-for="TransactionType" class="form-control" id="transactionType">
                                        <option value="">пњљ–њпњљ№•пњљпњљпњљпњљпњљпњљ</option>
                                        <option value="earn">пњљWпњљ[пњљIпњљпњљ</option>
                                        <option value="spend">пњљпњљпњљпњљпњљIпњљпњљ</option>
                                    </select>
                                    <span asp-validation-for="TransactionType" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="TransactionAmount" class="control-label">пњљпњљпњљпњљпњљпњљB *</label>
                                    <input asp-for="TransactionAmount" type="number" class="form-control" placeholder="пњљ–њпњљJпњљпњљпњљпњљпњљпњљB" min="1" />
                                    <span asp-validation-for="TransactionAmount" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Description" class="control-label">пњљпњљпњљпњљyпњљz *</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="пњљ–њпњљJпњљпњљпњљпњљyпњљz"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> пњљпњљпњљпњљпњљпњљ
                            </button>
                            <a href="@Url.Action("Index", "AdminWallet")" class="btn btn-secondary">
                                <i class="fas fa-times"></i> пњљпњљпњљпњљ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">пњљпњљпњљпњљпњљпњљпњљ</h6>
                </div>
                <div class="card-body">
                    <div class="text-center">
                        <i class="fas fa-coins fa-3x text-primary mb-3"></i>
                        <h5>пњљIпњљ∆•пњљпњљпњљ`пњљNпњљ∆ґпњљ</h5>
                    </div>
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="fas fa-check text-success"></i>
                            пњљWпњљ[пњљIпњљ∆°GпњљпњљпњљпњљпњљWпњљ[пњљќ§пњљпњљIпњљпњљ
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check text-success"></i>
                            пњљпњљпњљпњљпњљIпњљ∆°Gпњљqпњљќ§пњљпњљIпњљ∆§пњљпњљпњљпњљпњљ
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check text-success"></i>
                            пњљпњљпњљпњљпњљпњљBпњљпњљпњљпњљпњљjпњљпњљ0
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check text-success"></i>
                            пњљпњљпњљпњљyпњљzпњљ|пњљOпњљпњљпњљbпњљпњљпњљvпњљпњљ
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check text-success"></i>
                            пњљпњљпњљпњљпњљ|пњљяІYпњљЌЃпњљ
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">пњљ÷≥tпњљёІ@</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <button type="button" class="btn btn-outline-primary" onclick="setTransaction('earn', 100, '√±пњљпњљпњљпњљy')">
                            <i class="fas fa-calendar-check"></i> √±пњљпњљпњљпњљy (100пњљI)
                        </button>
                        <button type="button" class="btn btn-outline-success" onclick="setTransaction('earn', 500, 'пњљCпњљпњљпњљпњљпњљy')">
                            <i class="fas fa-gamepad"></i> пњљCпњљпњљпњљпњљпњљy (500пњљI)
                        </button>
                        <button type="button" class="btn btn-outline-info" onclick="setTransaction('earn', 1000, 'пњљпњљпњљ Љпњљпњљy')">
                            <i class="fas fa-gift"></i> пњљпњљпњљ Љпњљпњљy (1000пњљI)
                        </button>
                        <button type="button" class="btn btn-outline-warning" onclick="setTransaction('spend', 50, 'пњљCпњљпњљпњљпњљпњљO')">
                            <i class="fas fa-shopping-cart"></i> пњљCпњљпњљпњљпњљпњљO (50пњљI)
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        function setTransaction(type, amount, description) {
            document.getElementById('transactionType').value = type;
            document.getElementById('TransactionAmount').value = amount;
            document.getElementById('Description').value = description;
        }

        // пњљпњљпњљпњљпњљпњљпњљпњљ№Іпњљ…™пњљпњљпњљпњљпњљ
        document.getElementById('transactionType').addEventListener('change', function() {
            const type = this.value;
            const amountInput = document.getElementById('TransactionAmount');
            const descriptionInput = document.getElementById('Description');
            
            if (type === 'earn') {
                amountInput.placeholder = 'пњљ–њпњљJпњљnпњљWпњљ[пњљпњљпњљIпњљпњљ';
                descriptionInput.placeholder = 'пњљ–њпњљJпњљWпњљ[пњљIпњљ∆™пњљпњљпњљ]';
            } else if (type === 'spend') {
                amountInput.placeholder = 'пњљ–њпњљJпњљnпњљпњљпњљпњљпњљпњљпњљIпњљпњљ';
                descriptionInput.placeholder = 'пњљ–њпњљJпњљпњљпњљпњљпњљIпњљ∆™пњљпњљпњљ]';
            } else {
                amountInput.placeholder = 'пњљ–њпњљJпњљпњљпњљпњљпњљпњљB';
                descriptionInput.placeholder = 'пњљ–њпњљJпњљпњљпњљпњљyпњљz';
            }
        });
    </script>
}

